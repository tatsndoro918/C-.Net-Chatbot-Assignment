<Window x:Class="Cybersecurity_Awareness_Bot.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz — Blocked by James"
        Height="650" Width="850"
        MinHeight="600" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#0D0D0D">

    <Window.Resources>
        <Style x:Key="QuizButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="QuizOptionStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#F5F0E8"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#552583" Padding="20,15">
            <Grid>
                <StackPanel>
                    <TextBlock Text="🏀 CYBERSECURITY CHAMPIONSHIP QUIZ"
                               Foreground="#FFD700"
                               FontSize="23"
                               FontWeight="Bold"/>
                    <TextBlock Text="Test your defensive cybersecurity skills"
                               Foreground="#E8DFF0"/>
                </StackPanel>

                <Border Background="#FFD700"
                        Width="54" Height="54"
                        CornerRadius="27"
                        HorizontalAlignment="Right">
                    <TextBlock Text="23"
                               FontFamily="Impact"
                               FontSize="25"
                               Foreground="#111111"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,15,20,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock x:Name="ProgressTextBlock"
                           Foreground="#FFD700"
                           FontWeight="Bold"/>
                <ProgressBar x:Name="QuizProgressBar"
                             Height="8"
                             Margin="0,6,20,0"
                             Foreground="#FFD700"
                             Background="#333333"/>
            </StackPanel>

            <TextBlock x:Name="ScoreTextBlock"
                       Grid.Column="1"
                       Text="Score: 0"
                       Foreground="#FFD700"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="2"
                Background="#EE171717"
                BorderBrush="#552583"
                BorderThickness="1"
                CornerRadius="8"
                Margin="20,10"
                Padding="22">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="QuestionTextBlock"
                               Foreground="#F5F0E8"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,15"/>

                    <StackPanel x:Name="OptionsPanel"/>

                    <Border x:Name="FeedbackBorder"
                            Visibility="Collapsed"
                            CornerRadius="6"
                            Padding="13"
                            Margin="0,16,0,0">
                        <TextBlock x:Name="FeedbackTextBlock"
                                   Foreground="White"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Background="#111111" Padding="20,13">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SubmitAnswerButton"
                            Content="Submit Answer"
                            Style="{StaticResource QuizButton}"
                            Click="SubmitAnswerButton_Click"/>

                    <Button x:Name="NextQuestionButton"
                            Content="Next Question"
                            Style="{StaticResource QuizButton}"
                            Visibility="Collapsed"
                            Click="NextQuestionButton_Click"/>

                    <Button x:Name="RestartButton"
                            Content="Play Again"
                            Style="{StaticResource QuizButton}"
                            Visibility="Collapsed"
                            Click="RestartButton_Click"/>
                </StackPanel>

                <Button Content="Close"
                        HorizontalAlignment="Right"
                        Style="{StaticResource QuizButton}"
                        Background="#552583"
                        Foreground="White"
                        Click="CloseButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>